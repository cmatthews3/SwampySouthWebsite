---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  viewBox="0 0 40 40"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  class={className}
>
  <rect x="3" y="3" width="34" height="34" rx="3" fill="none" stroke="currentColor" stroke-width="1.25" />
  <path
    d="M8 22 Q 14 18, 20 22 T 32 22"
    stroke="currentColor"
    stroke-width="1.25"
    fill="none"
    stroke-linecap="round"
  />
  <path
    d="M8 28 Q 14 24, 20 28 T 32 28"
    stroke="currentColor"
    stroke-width="1.25"
    fill="none"
    stroke-linecap="round"
    opacity="0.45"
  />
</svg>
