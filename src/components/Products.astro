---
const products = [
  {
    name: 'IEP Assist',
    stage: 'In development',
    body: 'An AI drafting tool for special education teachers. It takes the data and notes a teacher already has and helps shape them into the formal language an IEP requires. The point is fewer late nights staring at a blank document.',
    note: 'Being built with Hynes Charter School Corporation in New Orleans. The furthest along of the three.',
  },
  {
    name: 'Project Touchline',
    stage: 'In development',
    body: 'An operations layer for grassroots soccer clubs at the Division 4 through 7 level. Rosters, fixtures, communications, and player and match records in one place, instead of scattered across spreadsheets, group chats, and someone’s notes app.',
    note: 'Being built alongside NOLA Ramparts FC.',
  },
  {
    name: 'Family AI Assistant',
    stage: 'Early prototype',
    body: 'A small, private AI for the household. A working Telegram bot today, running on a hybrid local and cloud setup so the things you’d rather keep close stay on a machine you own.',
    note: 'The earliest stage of the three. More working prototype than product right now.',
  },
];
---

<section class="py-12 sm:py-16">
  <div class="mx-auto max-w-prose px-6">
    <h2 class="font-serif text-2xl sm:text-3xl tracking-tight text-ink">
      What's in the works.
    </h2>

    <ol class="mt-10 space-y-12">
      {
        products.map((p, i) => (
          <li class="border-t border-ink/10 pt-8">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="font-serif text-xl sm:text-2xl text-ink">
                <span class="text-moss-deep/60 font-sans text-sm tracking-wide mr-2 align-middle">
                  0{i + 1}
                </span>
                {p.name}
              </h3>
              <span class="text-xs uppercase tracking-wider text-moss-deep/80 font-sans">
                {p.stage}
              </span>
            </div>
            <p class="mt-4 text-lg leading-relaxed text-ink/90">{p.body}</p>
            <p class="mt-3 text-base leading-relaxed text-ink/60">{p.note}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
