---
type Product = {
  num: string;
  category: string;
  title: string;
  body: string;
  status: string;
  href?: string;
};

const products: Product[] = [
  {
    num: '01',
    category: 'Education · AI',
    title: 'IEP Assist',
    body: "An AI drafting assistant for special education teachers. Writing an Individualized Education Program is hours of compliance-heavy writing per student, on top of a full classroom. IEP Assist takes the draft from blank page to a strong first cut so teachers can spend their energy on the parts that actually need a human.",
    status: 'Piloting with a local public school',
    href: 'https://iepassistrepofrontend-dev.up.railway.app/',
  },
  {
    num: '02',
    category: 'Soccer · Operations',
    title: 'Project Touchline',
    body: "The operations layer for grassroots soccer. Division 4–7 amateur and semi-pro clubs are usually run by a tiny crew — owners and coaches doubling as manager, social, and equipment coordinator alongside a day job. Touchline pulls roster, schedule, social, sponsorships, and match-day logistics into one place, with AI that drafts posts and recaps in the club's own voice.",
    status: 'Piloting with one club',
    href: 'https://socceroperationsassistant-production.up.railway.app/',
  },
  {
    num: '03',
    category: 'Family · AI',
    title: 'Project Winston',
    body: "A small, private AI for the household — calendar coordination, kid logistics, the everyday mental load of running a family. Genuinely useful without being creepy, and living somewhere that isn't a giant tech company's data center. The most exploratory of the four, and the one most likely to evolve as we learn what families actually want.",
    status: 'Early concept',
  },
  {
    num: '04',
    category: 'Fitness · AI',
    title: 'Project Reps',
    body: "An AI personal trainer for the average gym-goer — not the optimizer, not the part-time bodybuilder, just the person who wants to show up two or three times a week, do something reasonable, and not think about it too much. Builds the session around what you have, how much time you have, and how you feel today.",
    status: 'Early concept',
  },
];

const delayClass = ['', 'd1', 'd2', 'd3'];
---

<section class="block block-tint" id="products">
  <div class="container">
    <div class="section-head">
      <h2 class="reveal">Four products.<br />Four <span class="amber">communities.</span></h2>
      <p class="note reveal d1">// All four names are working titles — these aren't going to be the final ones.</p>
    </div>

    <div class="product-list">
      {products.map((p, i) => (
        <article class={`product-row reveal ${delayClass[i] ?? ''}`}>
          <div class="product-rail">
            <div class="num">{p.num}</div>
            <div class="cat">{p.category}</div>
          </div>
          <div class="product-info">
            <h4>{p.title}</h4>
            <p>{p.body}</p>
            <div class="footer-row">
              <span class="status muted"><span class="dot"></span>{p.status}</span>
              {p.href && (
                <a class="link" href={p.href} target="_blank" rel="noopener noreferrer">
                  Take a look <span class="arrow">→</span>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .container { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--pad); }

  .block { padding: 140px 0; }
  .block-tint { background: var(--moss-50); }

  .section-head { margin-bottom: 64px; }
  .section-head h2 {
    font-family: 'Rubik', sans-serif; font-weight: 600;
    font-size: clamp(40px, 4.6vw, 56px);
    line-height: 1.05; letter-spacing: -0.025em;
    margin: 0; color: var(--bayou); max-width: 16ch;
  }
  .section-head h2 .amber { color: var(--amber-deep); }
  .section-head .note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin: 18px 0 0;
  }

  .product-list { display: flex; flex-direction: column; gap: 24px; }
  .product-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 56px;
    align-items: start;
    background: var(--bone);
    border: 1px solid var(--silt);
    padding: 40px;
    transition: transform var(--t-med), box-shadow var(--t-med);
  }
  .product-row:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 48px -24px rgba(26, 31, 18, 0.18);
  }
  .product-rail { display: flex; flex-direction: column; gap: 10px; }
  .product-rail .num {
    font-family: 'Rubik', sans-serif; font-weight: 700;
    font-size: 56px; line-height: 0.95; letter-spacing: -0.03em;
    color: var(--moss-deep);
  }
  .product-rail .cat {
    font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .product-info { display: flex; flex-direction: column; gap: 14px; }
  .product-info h4 {
    font-family: 'Rubik', sans-serif; font-weight: 600;
    font-size: 34px; color: var(--bayou); margin: 0;
    letter-spacing: -0.02em; line-height: 1.1;
  }
  .product-info p {
    margin: 0; color: var(--ink-soft);
    font-size: 17px; line-height: 1.55; max-width: 64ch;
  }
  .product-info .footer-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-top: 8px;
    padding-top: 20px; border-top: 1px solid var(--silt);
    flex-wrap: wrap;
  }
  .product-info .status {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 500;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--moss-deep);
  }
  .product-info .status .dot { width: 7px; height: 7px; background: var(--moss); border-radius: 50%; }
  .product-info .status.muted { color: var(--ink-soft); }
  .product-info .status.muted .dot { background: var(--silt); }
  .product-info .link {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Rubik', sans-serif; font-weight: 600; font-size: 14px;
    color: var(--moss-deep);
    transition: color var(--t-fast);
  }
  .product-info .link:hover { color: var(--amber-deep); }
  .product-info .link .arrow {
    font-family: 'JetBrains Mono', monospace; font-weight: 400;
    transition: transform var(--t-fast);
  }
  .product-info .link:hover .arrow { transform: translateX(3px); }

  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: none; }
  .reveal.d1 { transition-delay: .08s; }
  .reveal.d2 { transition-delay: .16s; }
  .reveal.d3 { transition-delay: .24s; }

  @media (max-width: 900px) {
    .product-row { grid-template-columns: 1fr; gap: 24px; padding: 28px; }
    .product-rail { flex-direction: row; align-items: baseline; gap: 16px; }
    .product-rail .num { font-size: 40px; }
  }
</style>
