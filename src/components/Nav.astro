---
---

<nav class="top" id="topnav">
  <div class="row">
    <a class="brand" href="#top">
      <span class="m" aria-hidden="true"></span>
      <span>Swampy South <span class="amber">Labs</span></span>
    </a>
    <ul>
      <li><a href="#products" data-section="products">Products</a></li>
      <li><a href="#services" data-section="services">Services</a></li>
      <li><a href="#contact" data-section="contact">Contact</a></li>
    </ul>
    <a class="cta" href="#contact">Get in touch</a>
  </div>
</nav>

<style>
  nav.top {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: var(--nav-h);
    background: rgba(245, 241, 230, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--silt);
  }
  nav.top .row {
    max-width: var(--maxw); margin: 0 auto;
    height: 100%; padding: 0 var(--pad);
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center; gap: 24px;
  }
  nav.top .brand {
    display: flex; align-items: center; gap: 14px;
    font-family: 'Rubik', sans-serif; font-weight: 700; font-size: 22px;
    letter-spacing: -0.02em; color: var(--bayou);
  }
  nav.top .brand .m {
    width: 44px; height: 44px;
    background: url('/assets/mark.svg') center/contain no-repeat;
  }
  nav.top .brand .amber { color: var(--amber-deep); }
  nav.top ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 28px; }
  nav.top ul a {
    font-family: 'Manrope', sans-serif; font-weight: 500; font-size: 14px;
    color: var(--ink-soft);
    transition: color var(--t-fast);
  }
  nav.top ul a:hover, nav.top ul a.active { color: var(--bayou); }
  nav.top .cta {
    justify-self: end;
    font-family: 'Rubik', sans-serif; font-weight: 600; font-size: 13px;
    padding: 9px 16px;
    background: var(--bayou); color: var(--bone);
    transition: background var(--t-fast);
    letter-spacing: -0.005em;
  }
  nav.top .cta:hover { background: #000; }

  @media (max-width: 900px) {
    nav.top ul { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('topnav');
  if (nav) {
    const links = nav.querySelectorAll<HTMLAnchorElement>('a[data-section]');
    const sections = ['products', 'services', 'contact'];

    function updateNav() {
      let active: string | null = null;
      for (const id of sections) {
        const el = document.getElementById(id);
        if (!el) continue;
        if (el.getBoundingClientRect().top < 200) active = id;
      }
      links.forEach((a) => {
        a.classList.toggle('active', a.dataset.section === active);
      });
    }
    document.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  }
</script>
