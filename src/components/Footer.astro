---
const year = new Date().getFullYear();
const pathname = Astro.url.pathname;
const onLabs = pathname === '/labs' || pathname === '/labs/';
const home = (anchor: string) => (onLabs ? `/${anchor}` : anchor);
---

<footer>
  <div class="row">
    <div class="name"><span class="amber">Swampy South</span> Labs</div>
    <ul>
      <li><a href={home('#services')}>Services</a></li>
      <li><a href={home('#how-we-work')}>How we work</a></li>
      <li><a href="/labs">Labs</a></li>
      <li><a href={home('#contact')}>Contact</a></li>
    </ul>
  </div>
  <div class="copy">
    <span>© {year} Swampy South Labs · New Orleans, LA</span>
  </div>
</footer>

<style>
  footer {
    background: var(--bayou); color: rgba(245, 241, 230, 0.6);
    padding: 56px var(--pad) 32px;
  }
  footer .row {
    max-width: var(--maxw); margin: 0 auto;
    display: flex; justify-content: space-between; align-items: center; gap: 24px;
    flex-wrap: wrap;
  }
  footer .name {
    font-family: 'Rubik', sans-serif; font-weight: 700; font-size: 18px;
    letter-spacing: -0.02em; color: var(--bone);
  }
  footer .name .amber { color: var(--amber-warm); }
  footer ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 24px; }
  footer ul a {
    font-family: 'Manrope', sans-serif; font-size: 15px;
    transition: color var(--t-fast);
  }
  footer ul a:hover { color: var(--amber-warm); }
  footer .copy {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid rgba(245, 241, 230, 0.12);
    max-width: var(--maxw); margin-left: auto; margin-right: auto;
    font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase; color: rgba(245, 241, 230, 0.4);
    display: flex; justify-content: space-between;
  }

  @media (max-width: 900px) {
    footer .row { flex-direction: column; align-items: flex-start; }
    footer .copy { flex-direction: column; gap: 12px; }
  }
</style>
