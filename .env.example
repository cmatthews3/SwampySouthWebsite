# The Google Sheet ID where signups are written.
# Find it in the sheet URL: https://docs.google.com/spreadsheets/d/<THIS-PART>/edit
GOOGLE_SHEETS_ID=

# The full contents of your service account's JSON key file.
# Paste the entire JSON (including newlines inside the private_key string).
# In Railway: paste the file contents as-is into the variable value.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Node adapter host/port. Railway injects PORT for you. Set HOST=0.0.0.0 in Railway.
HOST=0.0.0.0
PORT=4321
