# Local path to the subscribers CSV. On Railway, point this at a mounted volume.
SUBSCRIBERS_FILE=./data/subscribers.csv

# Long random string. Hit /api/subscribers.csv?token=<this> to download the list.
# Leave blank to disable the download endpoint.
SUBSCRIBERS_DOWNLOAD_TOKEN=

# Local path to the contact-form CSV. On Railway, point this at a mounted volume.
CONTACT_FILE=./data/contact-messages.csv

# Long random string. Hit /api/contact-messages.csv?token=<this> to download the list.
# Leave blank to disable the download endpoint.
CONTACT_DOWNLOAD_TOKEN=

# Node adapter host/port. Railway injects PORT for you. Set HOST=0.0.0.0 in Railway.
HOST=0.0.0.0
PORT=4321

# Umami analytics. Both must be set for the script tag to render.
# Leave blank in dev to skip analytics. Set in Railway for production.
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
